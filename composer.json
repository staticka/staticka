{
  "name": "staticka/staticka",
  "description": "Yet another PHP static site generator.",
  "keywords": [ "simple", "static-site", "site-generator" ],
  "homepage": "https://roug.in/staticka/",
  "license": "MIT",
  "authors":
  [
    {
      "email": "rougingutib@gmail.com",
      "homepage": "https://roug.in/",
      "name": "Rougin Gutib",
      "role": "Software Engineer"
    }
  ],
  "require":
  {
    "php": ">=5.3.0",
    "erusev/parsedown": "~1.6",
    "symfony/yaml": "*"
  },
  "require-dev":
  {
    "rougin/slytherin": "~0.9",
    "phpunit/phpunit": "*",
    "sanmai/phpunit-legacy-adapter": "*"
  },
  "autoload":
  {
    "psr-4":
    {
      "Staticka\\": "src"
    }
  },
  "autoload-dev":
  {
    "psr-4":
    {
      "Staticka\\": "tests"
    }
  },
  "scripts":
  {
    "analyze": "phpstan analyse",
    "restyle": "php-cs-fixer fix --config=phpstyle.php",
    "test": "phpunit"
  }
}
